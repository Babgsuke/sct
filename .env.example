# sct — Environment Variables
# Copy this to .env and fill in your values

# Telegram Bot (used in main.sh for install notifications)
CHATID=your_telegram_chat_id
CHATIDX=your_secondary_chat_id
BOT_KEY=your_telegram_bot_token
BOT_KEYX=your_secondary_bot_token

# SMTP / Backup (used in main.sh for msmtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Server
TIMEZONE=Asia/Jakarta
